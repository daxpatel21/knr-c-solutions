# =============================================================================
# .clang-format — Strict K&R C Style
# =============================================================================
# Based on: The C Programming Language, 2nd Ed. by Kernighan & Ritchie
#
# Key rules:
#   - Tabs for indentation (not spaces)
#   - Function opening brace on NEW line
#   - if/while/for/do opening brace on SAME line
#   - Space after keywords (if, while, for, return)
#   - No space before function call parentheses
#   - 79 character line limit
# =============================================================================

BasedOnStyle: LLVM

# Indentation — tabs, width 4
IndentWidth:        8
TabWidth:           8
UseTab:             ForIndentation
ContinuationIndentWidth: 8

# Line length
ColumnLimit:        79

# Braces — K&R style
# Function: brace on NEW line
# if/while/for: brace on SAME line
BreakBeforeBraces:  WebKit

# Spaces
SpaceBeforeParens:          ControlStatements   # space in: if (, while (, for (
SpaceBeforeCpp11BracedList: false
SpaceInEmptyParentheses:    false
SpacesInParentheses:        false
SpacesInSquareBrackets:     false
SpaceAfterCStyleCast:       false

# Alignment
AlignConsecutiveAssignments:    false
AlignConsecutiveDeclarations:   false
AlignTrailingComments:          true

# Pointers — K&R puts * with variable name: int *p
PointerAlignment:   Right

# Short constructs — keep them broken out for clarity
AllowShortFunctionsOnASingleLine:   None
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine:        false
AllowShortBlocksOnASingleLine:       Never

# Include order — don't sort, keep as written
SortIncludes:   false

# Max empty lines
MaxEmptyLinesToKeep: 1
